{
  "id": "bootstrap-missing-ai-uses-host-agent",
  "description": "已初始化但缺 AI Provider 时，Codex 默认 bootstrap 走宿主 Agent workflow，不能因 internal AI Provider 缺失而失败。",
  "fixture": {
    "ai": "missing",
    "daemon": "stopped",
    "initialized": true,
    "knowledge": "empty",
    "project": "minimal-node",
    "projectRoot": "explicit"
  },
  "turns": [
    {
      "user": "开始 Alembic 知识挖掘"
    }
  ],
  "expect": {
    "toolCalls": [
      {
        "name": "alembic_codex_status",
        "arguments": {
          "projectRoot": "$projectRoot"
        },
        "result": {
          "success": true
        }
      },
      {
        "name": "alembic_bootstrap",
        "arguments": {
          "projectRoot": "$projectRoot"
        },
        "result": {
          "success": true,
          "data.serviceBoundary.executionPath": "plugin-owned-codex-facing",
          "data.serviceBoundary.owner": "alembic-plugin"
        }
      }
    ],
    "sideEffects": {
      "daemonEnsureCalled": false,
      "initMarkerWritten": false,
      "jobCreated": false,
      "savedProjectRootWritten": true,
      "secretWritten": false
    },
    "assistant": {
      "mustMention": ["host-agent bootstrap", "Mission Briefing"],
      "mustNotMention": ["AI Provider", "alembic_codex_ai_config", "知识挖掘任务已入队"]
    }
  }
}
