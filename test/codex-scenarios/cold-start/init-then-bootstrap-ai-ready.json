{
  "id": "init-then-bootstrap-host-agent",
  "description": "用户先初始化再要求知识挖掘，Codex 默认应启动 host-agent bootstrap workflow，不依赖 internal AI Provider 或创建 internal job。",
  "fixture": {
    "ai": "missing",
    "daemon": "stopped",
    "initialized": false,
    "knowledge": "none",
    "project": "minimal-node",
    "projectRoot": "explicit"
  },
  "turns": [
    {
      "user": "初始化 Alembic"
    },
    {
      "user": "开始 Alembic 知识挖掘"
    }
  ],
  "expect": {
    "toolCalls": [
      {
        "name": "alembic_codex_status",
        "arguments": {
          "projectRoot": "$projectRoot"
        },
        "result": {
          "success": true,
          "data.projectRootResolution.trust": "trusted"
        }
      },
      {
        "name": "alembic_codex_init",
        "arguments": {
          "projectRoot": "$projectRoot"
        },
        "result": {
          "success": true
        }
      },
      {
        "name": "alembic_bootstrap",
        "arguments": {
          "projectRoot": "$projectRoot"
        },
        "result": {
          "success": true,
          "data.serviceBoundary.executionPath": "plugin-owned-codex-facing",
          "data.serviceBoundary.owner": "alembic-plugin"
        }
      }
    ],
    "sideEffects": {
      "daemonEnsureCalled": false,
      "initMarkerWritten": true,
      "jobCreated": false,
      "savedProjectRootWritten": true,
      "secretWritten": false
    },
    "state": {
      "aiProvider": null,
      "aiReady": false,
      "initializedAfterRun": true,
      "workspace": {
        "configExists": true,
        "databaseExists": true,
        "knowledgeExists": true,
        "runtimeExists": true
      }
    },
    "assistant": {
      "mustMention": ["host-agent bootstrap", "Mission Briefing"],
      "mustNotMention": ["没有启动", "AI Provider", "知识挖掘任务已入队"]
    }
  }
}
