{
  "id": "codex",
  "displayName": "Codex",
  "description": "Codex distribution entry for the Alembic Codex plugin marketplace shell and pinned runtime package.",
  "marketplace": {
    "name": "gxfn",
    "displayName": "GxFn",
    "manifestPath": ".agents/plugins/marketplace.json"
  },
  "runtime": {
    "channelId": "codex",
    "mode": "plugin",
    "pluginHost": "codex",
    "env": {
      "ALEMBIC_CHANNEL_ID": "codex",
      "ALEMBIC_PLUGIN_HOST": "codex",
      "ALEMBIC_RUNTIME_MODE": "plugin"
    }
  },
  "plugins": [
    {
      "name": "alembic-codex",
      "path": "plugins/alembic-codex",
      "marketplaceEntry": "alembic-codex",
      "runtimePackage": "@gxfn/alembic-codex-runtime",
      "runtimeMode": "plugin",
      "runtimeSpecifier": "@gxfn/alembic-codex-runtime@0.2.0",
      "shellEntry": "bin/alembic-codex-start.mjs",
      "pluginHost": "codex",
      "distributionRepo": "GxFn/AlembicCodex",
      "runtimeBin": "alembic-codex-mcp",
      "releaseScript": "release:codex-plugin",
      "smokeScript": "smoke:codex-plugin"
    }
  ],
  "packages": [
    {
      "name": "@gxfn/alembic-codex-runtime",
      "registry": "npm",
      "installScope": "marketplace-shell-runtime",
      "specifier": "@gxfn/alembic-codex-runtime@0.2.0",
      "version": "0.2.0",
      "binaries": [
        "alembic-codex-mcp"
      ],
      "usedBy": [
        "alembic-codex"
      ]
    }
  ]
}
