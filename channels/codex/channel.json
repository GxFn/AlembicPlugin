{
  "id": "codex",
  "displayName": "Codex",
  "description": "Codex distribution entry for the Alembic Codex plugin and embedded portable runtime artifact.",
  "marketplace": {
    "name": "gxfn",
    "displayName": "GxFn",
    "manifestPath": ".agents/plugins/marketplace.json"
  },
  "runtime": {
    "channelId": "codex",
    "mode": "plugin",
    "pluginHost": "codex",
    "env": {
      "ALEMBIC_CHANNEL_ID": "codex",
      "ALEMBIC_PLUGIN_HOST": "codex",
      "ALEMBIC_RUNTIME_MODE": "plugin"
    }
  },
  "plugins": [
    {
      "name": "alembic-codex",
      "path": "plugins/alembic-codex",
      "marketplaceEntry": "alembic-codex",
      "runtimePackage": "alembic-ai",
      "runtimeMode": "plugin",
      "runtimeSpecifier": "./runtime.tgz",
      "embeddedRuntimePath": "runtime",
      "pluginHost": "codex",
      "distributionRepo": "GxFn/AlembicCodex",
      "runtimeBin": "alembic-codex-mcp",
      "releaseScript": "release:codex-plugin",
      "smokeScript": "smoke:codex-plugin"
    }
  ],
  "packages": [
    {
      "name": "alembic-ai",
      "registry": "portable-artifact",
      "installScope": "embedded-plugin-runtime",
      "artifact": "plugins/alembic-codex/runtime.tgz",
      "version": "0.2.0",
      "binaries": [
        "alembic-codex-mcp"
      ],
      "usedBy": [
        "alembic-codex"
      ]
    }
  ]
}
